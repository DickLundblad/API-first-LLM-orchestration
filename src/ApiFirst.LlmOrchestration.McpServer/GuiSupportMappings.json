{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Maps API operations to GUI routes/features in the InternalAI frontend",
  "guiBaseUrl": "http://localhost:3000",
  "mappings": [
    {
      "operationId": "GetTeamMembers",
      "guiRoute": "/team",
      "guiFeature": "Team Member List",
      "description": "View and search all team members in a table view"
    },
    {
      "operationId": "GetTeamMember",
      "guiRoute": "/team/{id}",
      "guiFeature": "Team Member Detail",
      "description": "View and edit individual team member profile details",
      "pathParameters": {
        "id": "memberId"
      }
    },
    {
      "operationId": "UpdateTeamMember",
      "guiRoute": "/team/{id}",
      "guiFeature": "Team Member Edit",
      "description": "Edit team member profile via the detail page",
      "pathParameters": {
        "id": "memberId"
      }
    },
    {
      "operationId": "DeleteTeamMember",
      "guiRoute": "/team/{id}",
      "guiFeature": "Team Member Delete",
      "description": "Delete team member from detail page (requires permissions)",
      "pathParameters": {
        "id": "memberId"
      }
    },
    {
      "operationId": "GetCourses",
      "guiRoute": "/courses",
      "guiFeature": "Courses List",
      "description": "View and search all courses with filtering"
    },
    {
      "operationId": "GetCourse",
      "guiRoute": "/courses",
      "guiFeature": "Course Detail View",
      "description": "View course details in the courses page",
      "notes": "Course details shown in same page, not separate route"
    },
    {
      "operationId": "UpdateCourse",
      "guiRoute": "/courses",
      "guiFeature": "Course Edit",
      "description": "Edit course details via the courses page"
    },
    {
      "operationId": "CreateCourse",
      "guiRoute": "/courses",
      "guiFeature": "Course Creation",
      "description": "Create new course via the courses page"
    },
    {
      "operationId": "ApproveCourse",
      "guiRoute": "/courses",
      "guiFeature": "Course Approval",
      "description": "Approve proposed course (Manager+ only)"
    },
    {
      "operationId": "ArchiveCourse",
      "guiRoute": "/courses",
      "guiFeature": "Course Archive Toggle",
      "description": "Archive or unarchive a course (Manager+ only)"
    },
    {
      "operationId": "EnrollCourse",
      "guiRoute": "/team/{id}",
      "guiFeature": "Course Enrollment",
      "description": "Enroll team member in courses via their detail page",
      "pathParameters": {
        "id": "consultantId"
      }
    },
    {
      "operationId": "GetConsultantCourses",
      "guiRoute": "/team/{id}",
      "guiFeature": "Team Member Courses",
      "description": "View team member's enrolled courses on their detail page",
      "pathParameters": {
        "id": "consultantId"
      }
    },
    {
      "operationId": "Login",
      "guiRoute": "/login",
      "guiFeature": "User Login",
      "description": "User authentication page"
    },
    {
      "operationId": "ForgotPassword",
      "guiRoute": "/forgot-password",
      "guiFeature": "Password Reset Request",
      "description": "Request password reset email"
    },
    {
      "operationId": "ResetPassword",
      "guiRoute": "/reset-password",
      "guiFeature": "Password Reset Form",
      "description": "Reset password with token from email"
    },
    {
      "operationId": "VerifyEmail",
      "guiRoute": "/verify-email",
      "guiFeature": "Email Verification",
      "description": "Verify email address with token"
    }
  ],
  "notes": [
    "GUI routes are relative to guiBaseUrl",
    "Path parameters in curly braces {id} should be replaced with actual values",
    "Some operations share the same GUI route but different features/modals",
    "Operations not listed here have no direct GUI equivalent",
    "GUI may be available at different URL in production"
  ]
}
